<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="TransportDTO" table="ST_TRANSPORT">

		<id name="id" type="java.lang.Long">
			<column name="ID" />
			<generator class="increment" />
		</id>

		<property name="transportId" type="java.lang.Long">
			<column name="TRANSPORT_ID" />
		</property>

		<property name="vehicleNumber" type="java.lang.String">
			<column name="VEHICLE_NUMBER" />
		</property>

		<property name="driverName" type="java.lang.String">
			<column name="DRIVER_NAME" />
		</property>

		<property name="vehicleType" type="java.lang.String">
			<column name="VEHICLE_TYPE" />
		</property>

		<property name="transportStatus" type="java.lang.String">
			<column name="TRANSPORT_STATUS" />
		</property>
	</class>

</hibernate-mapping>