<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="PodcastDTO" table="ST_PODCAST">

		<id name="id" type="java.lang.Long">
			<column name="ID" />
			<generator class="increment" />
		</id>

		<property name="episode_title" type="java.lang.String">
			<column name="EPISODE_TITLE" />
		</property>

		<property name="host_name" type="java.lang.String">
			<column name="HOST_NAME" />
		</property>

		<property name="duration" type="java.lang.String">
			<column name="DURATION" />
		</property>

		<property name="release_date" type="java.util.Date">
			<column name="RELEASE_DATE" />
		</property>

	</class>

</hibernate-mapping>