<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="SessionDTO" table="ST_SESSION">

		<id name="sessionId" column="SESSION_ID" type="long">
			<generator class="increment" />
		</id>

		<property name="sessionToken" column="SESSION_TOKEN"
			type="string" />
		<property name="userName" column="USER_NAME" type="string" />
		<property name="sessionStatus" column="SESSION_STATUS"
			type="string" />
		<property name="loginTime" column="LOGIN_TIME"
			type="java.time.LocalDateTime" />
		<property name="logoutTime" column="LOGOUT_TIME"
			type="java.time.LocalDateTime" />

	</class>

</hibernate-mapping>