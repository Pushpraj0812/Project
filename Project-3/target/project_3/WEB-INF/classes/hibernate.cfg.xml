<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
		"-//Hibernate/Hibernate Configuration DTD 3.0//EN"
		"http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>

	<!-- When you start your Hibernate session, it reads this file to know which 
		database to connect to and how to map your Java classes to tables. -->

	<!-- This file: -->
	<!-- 1. Tells Hibernate how to connect to your MySQL database. -->
	<!-- 2. Configures SQL dialect, schema update rules, and logging. -->
	<!-- 3. Optionally supports caching and connection pooling (commented out 
		here). -->
	<!-- 4. Lists all the Java-to-database mapping files. -->


	<session-factory>
		<property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>

		<property name="hibernate.connection.url">jdbc:mysql://ORS_Project3-mysql:3306/project_3</property>

		<!-- <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/project_3</property> -->

		<property name="hibernate.connection.username">root</property>
		<property name="hibernate.connection.password">root</property>


		<property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

		<property name="hbm2ddl.auto">update</property>
		<property name="show_sql">true</property> <!-- To print sql -->

		<!-- Second-level cache (EhCache) is commented out. Used for caching objects 
			across sessions. -->
		<!-- <property name="hibernate.cache.provider_class"> org.hibernate.cache.EhCacheProvider</property> 
			<property name="hibernate.cache.use_second_level_cache"> true</property> -->


		<!-- hibernate DCP c3p0 Configuration -->
		<!-- <property name="hibernate.c3p0.min_size">10</property> default 3 <property 
			name="hibernate.c3p0.max_size">100</property>default 20 Acquired increment 
			by default =3 <property name="hibernate.c3p0.timeout">10</property>default 
			20 <property name="hibernate.c3p0.max_statements">50</property> <property 
			name="hibernate.c3p0.idle_test_period">3000</property> -->


		<mapping resource="in/co/rays/project_3/hbm/UserDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/StudentDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/CollegeDTO.hbm.xml" />
		<mapping resource="in/co/rays/project_3/hbm/CourseDTO.hbm.xml" />
		<mapping resource="in/co/rays/project_3/hbm/RoleDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/MarksheetDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/TimetableDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/FacultyDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/SubjectDTO.hbm.xml" />
		<mapping
			resource="in/co/rays/project_3/hbm/ProductDTO.hbm.xml" />
	</session-factory>
</hibernate-configuration>